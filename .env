# 开发环境配置 - 通过 Vite 代理转发到后端
VITE_API_BASE_URL=/api

# 后端服务器基础URL（用于静态资源如头像）
VITE_SERVER_BASE_URL=http://localhost:8080/delicious

# 生产环境配置
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_SERVER_BASE_URL=https://api.yourdomain.com

# 应用配置
VITE_APP_TITLE=美味外卖

# Token配置
VITE_ACCESS_TOKEN_KEY=access_token
VITE_REFRESH_TOKEN_KEY=refresh_token
VITE_TOKEN_EXPIRE_KEY=token_expire